{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "vcs": {
    "clientKind": "git",
    "useIgnoreFile": true,
    "root": "."
  },
  "files": {
    "includes": [
      "**",
      "!data",
      "!db",
      "!node_modules",
      "!target",
      "!**/target",
      "!dist",
      "!**/dist",
      "!coverage",
      "!**/coverage",
      "!state"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  }
}

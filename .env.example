# ===========================================
# European Rail Meta-Router — Environment
# ===========================================

# MOTIS
MOTIS_HOST=motis
MOTIS_PORT=8080

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL / PostGIS
DB_HOST=db
DB_PORT=5432
DB_NAME=stations
DB_USER=railrouter
DB_PASSWORD=changeme_in_production

# OJP Endpoints (set to "mock" to use built-in mock data)
OJP_MODE=mock
OJP_ENDPOINT_DE=https://api.mobilithek.info/ojp
OJP_ENDPOINT_CH=https://api.opentransportdata.swiss/ojp
OJP_ENDPOINT_AT=https://api.mobilitaetsdaten.gv.at/ojp

# OJP API Keys (leave empty for mock mode)
OJP_KEY_DE=
OJP_KEY_CH=
OJP_KEY_AT=

# Rate Limits (requests per minute per endpoint)
RATE_LIMIT_DE=100
RATE_LIMIT_CH=60
RATE_LIMIT_AT=60

# App
NODE_ENV=development
PORT=3000
